<script>
/* ============================================================
   GLOSSARY
============================================================ */
const GLOSSARY = {
  "LLC":"Limited Liability Company — a flexible structure whose owners (members) aren't personally responsible for business debts.",
  "C Corporation":"A formal entity owned by shareholders through stock; it can issue multiple classes of stock and is built to raise capital.",
  "S Corp":"A federal tax status elected with the IRS (via Form 2553), not a separate entity formed with a state.",
  "IPO":"Initial Public Offering — when a company first sells shares of its stock to the public.",
  "venture capital":"Investor funding for high-growth companies, usually in exchange for preferred stock.",
  "preferred stock":"A class of stock with priority rights that venture capital investors typically require.",
  "Registered Agent":"A person or company that receives official state and legal mail for a business at a physical in-state address.",
  "Virtual Address":"A secure U.S. mailing address where incoming mail is scanned and uploaded to the customer's dashboard.",
  "Form 1583":"A USPS form that gives Bizee written consent to receive and handle a customer's mail for a Virtual Address.",
  "Colleckt":"The USPS-approved system Bizee uses to verify a customer's ID and proof of address before Form 1583 is signed.",
  "DBA":"Doing Business As — a filing that lets a business operate under a name other than its legal name.",
  "Assumed Business Name":"Another term for a DBA — a name a business assumes to operate under, separate from its legal name.",
  "Trademark":"Legal protection for a brand's name, logo, or slogan, registered nationally with the USPTO.",
  "Amendment":"A state filing that updates public-record company information, such as the name, members, or authorized shares.",
  "EIN":"Employer Identification Number — a nine-digit IRS tax ID for a business; it isn't public information.",
  "Form SS-4":"The IRS application form used to obtain an EIN.",
  "Form 2553":"The IRS form a corporation or LLC files to elect S Corp tax status.",
  "Form 1023":"The IRS application a nonprofit files for 501(c)(3) tax-exempt status. Bizee does not file it.",
  "Form 8822-B":"The IRS form used to update business information tied to an EIN, such as the responsible party.",
  "Foreign Qualification":"A filing that lets an existing company legally operate in a state other than where it was formed.",
  "Certificate of Good Standing":"A state document confirming a business is active, registered, and compliant.",
  "COGS":"Certificate of Good Standing — a state document confirming a business is active and compliant.",
  "administratively dissolved":"When the state shuts down a business for non-compliance, such as missed filings or a lapsed agent.",
  "voluntarily":"In dissolution, when the owners themselves formally close the business with the state.",
  "withdrawal":"Ending a company's foreign qualification in a state. Bizee does not offer this filing.",
  "501(c)(3)":"Federal tax-exempt status for nonprofits, applied for with the IRS using Form 1023 — Bizee doesn't file it.",
  "Operating Agreement":"An LLC's internal rulebook covering ownership, decisions, and profit sharing among members.",
  "Bylaws":"A corporation's internal rulebook covering officer roles, voting, and meetings.",
  "Banking Resolution":"A document authorizing an individual to open and manage the company's bank account.",
  "Organizer":"The person who signs and files an LLC's formation papers; their role ends once the company is formed.",
  "Incorporator":"The corporation/nonprofit equivalent of an Organizer — signs and files the Articles, then their role ends.",
  "franchise tax":"A recurring state tax or fee some states charge a business regardless of revenue.",
  "Franchise Tax Report":"The name Delaware and Texas use for the recurring filing that ties to franchise tax.",
  "disregarded entity":"A single-member LLC the IRS treats as part of its owner for tax purposes.",
  "partnership":"A business co-owned by two or more people who share profits, management, and liability.",
  "responsible party":"The person who ultimately owns or controls a business, named on the EIN application.",
  "membership percentages":"How LLC ownership is measured — by percentage of the company rather than by stock shares.",
  "ITIN":"Individual Taxpayer Identification Number — a tax ID for people who can't get an SSN.",
  "Comptroller":"In Texas, the agency that handles franchise tax and a company's mailing address, separate from the Secretary of State.",
  "Secretary of State":"The state office that handles business formation and public records.",
  "PIR":"Public Information Report — the part of the Texas annual filing that updates ownership, officer, and agent details.",
  "Service of Process":"Official delivery of legal documents, such as a lawsuit, to a business.",
  "State Filings Bundle":"A $99/year subscription that waives Bizee's processing fee on supported state filings for a company.",
  "authorized shares":"The maximum number of shares a corporation is allowed to issue, listed in its Articles of Incorporation."
};
// surface forms -> canonical glossary key, longest patterns first
const GLOSS_PATTERNS = [
  ["Certificate of Good Standing","Certificate of Good Standing"],
  ["Assumed Business Name","Assumed Business Name"],
  ["State Filings Bundle","State Filings Bundle"],
  ["administratively dissolved","administratively dissolved"],
  ["Administratively Dissolved","administratively dissolved"],
  ["membership percentages","membership percentages"],
  ["Franchise Tax Report","Franchise Tax Report"],
  ["responsible party","responsible party"],
  ["Responsible Party","responsible party"],
  ["Operating Agreement","Operating Agreement"],
  ["Foreign Qualification","Foreign Qualification"],
  ["foreign[- ]qualif\\w+","Foreign Qualification"],
  ["disregarded entity","disregarded entity"],
  ["Banking Resolution","Banking Resolution"],
  ["preferred stock","preferred stock"],
  ["venture capital","venture capital"],
  ["authorized shares","authorized shares"],
  ["Secretary of State","Secretary of State"],
  ["Service of Process","Service of Process"],
  ["C Corporation","C Corporation"],
  ["C[- ]Corp\\b","C Corporation"],
  ["S Corporation","S Corp"],
  ["S[- ]Corp\\b","S Corp"],
  ["Registered Agent","Registered Agent"],
  ["Virtual Address","Virtual Address"],
  ["franchise tax","franchise tax"],
  ["Franchise Tax","franchise tax"],
  ["Incorporator","Incorporator"],
  ["Organizer","Organizer"],
  ["Form 1583","Form 1583"],
  ["Form SS-4","Form SS-4"],
  ["Form 2553","Form 2553"],
  ["Form 1023","Form 1023"],
  ["Form 8822-B","Form 8822-B"],
  ["501\\(c\\)\\(3\\)","501(c)(3)"],
  ["Operating","Operating Agreement"],
  ["Trademark","Trademark"],
  ["trademark","Trademark"],
  ["Amendment","Amendment"],
  ["Colleckt","Colleckt"],
  ["Comptroller","Comptroller"],
  ["voluntarily","voluntarily"],
  ["withdraw","withdrawal"],
  ["Withdraw","withdrawal"],
  ["Bylaws","Bylaws"],
  ["COGS","COGS"],
  ["ITIN","ITIN"],
  ["IPO","IPO"],
  ["PIR","PIR"],
  ["DBA","DBA"],
  ["EIN","EIN"],
  ["LLC","LLC"]
];

function escHtml(s){return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");}

function addGlossaryLinks(raw){
  // Work on escaped text; wrap first occurrence of each canonical key only once.
  let text = escHtml(raw);
  const used = new Set();
  // protect already-wrapped spans by tokenizing
  for(const [pat, key] of GLOSS_PATTERNS){
    if(used.has(key)) continue;
    if(!GLOSSARY[key]) continue;
    const re = new RegExp("(?<![\\w-])("+pat+")(?![\\w-])");
    const m = text.match(re);
    if(m){
      const start = m.index, end = start + m[0].length;
      // skip if inside an existing span tag region (rough check)
      const before = text.slice(0,start);
      const openTags = (before.match(/<span/g)||[]).length;
      const closeTags = (before.match(/<\/span/g)||[]).length;
      if(openTags>closeTags) continue;
      const word = m[1];
      text = before + '<span class="gloss" data-term="'+key+'">'+word+'</span>' + text.slice(end);
      used.add(key);
    }
  }
  return text;
}

/* glossary popup behavior */
const pop = document.getElementById('gloss-pop');
function showGlossary(term, x, y){
  if(!GLOSSARY[term]) return;
  pop.innerHTML = '<b>'+escHtml(term)+'</b>'+escHtml(GLOSSARY[term]);
  pop.style.display='block';
  const w = pop.offsetWidth, h = pop.offsetHeight;
  let px = Math.min(x, window.innerWidth - w - 12);
  let py = y + 14;
  if(py + h > window.innerHeight - 8) py = y - h - 14;
  pop.style.left = Math.max(8,px)+'px';
  pop.style.top = Math.max(8,py)+'px';
}
function hideGlossary(){ pop.style.display='none'; }
document.addEventListener('click',e=>{
  const t = e.target.closest('.gloss');
  if(t){ e.stopPropagation(); showGlossary(t.dataset.term, e.clientX, e.clientY); }
  else if(!e.target.closest('#gloss-pop')) hideGlossary();
});
window.addEventListener('scroll',hideGlossary,true);
window.addEventListener('resize',hideGlossary);

