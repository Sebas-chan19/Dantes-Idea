const NEXT_STEPS = {
  "Entity Types & Tax Classifications":"Re-read the LLC, C Corp, Nonprofit and S Corp pages — focus on members vs shareholders, why a C Corp fits VC/IPO, that an S Corp is an IRS status, and the S Corp eligibility limits.",
