<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bizee Operations Quiz — Knowledge Check</title>
<style>
  :root{
    --blue:#2563eb; --blue-dark:#1d4ed8; --navy:#0f1f3d; --navy-2:#16294d;
    --green:#10b981; --green-bg:#ecfdf5; --green-bd:#6ee7b7;
    --orange:#f59e0b; --orange-bg:#fffbeb; --orange-bd:#fcd34d;
    --red:#ef4444; --red-bg:#fef2f2; --red-bd:#fca5a5;
    --ink:#0f172a; --ink-2:#334155; --muted:#64748b; --line:#e2e8f0;
    --paper:#f6f8fc; --card:#ffffff;
    --mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace;
    --sans:system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    --r:14px; --shadow:0 1px 2px rgba(15,31,61,.06),0 8px 24px rgba(15,31,61,.06);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{font-family:var(--sans);color:var(--ink);background:var(--paper);line-height:1.55;-webkit-font-smoothing:antialiased}
  .wrap{max-width:880px;margin:0 auto;padding:24px 20px 80px}

  /* Header */
  header.app{
    background:linear-gradient(135deg,var(--navy),var(--navy-2));
    color:#fff;border-radius:var(--r);padding:22px 24px;box-shadow:var(--shadow);
    position:relative;overflow:hidden
  }
  header.app::after{content:"";position:absolute;right:-40px;top:-40px;width:180px;height:180px;
    background:radial-gradient(closest-side,rgba(37,99,235,.55),transparent);border-radius:50%}
  .eyebrow{font-family:var(--mono);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;
    color:#9db4e6;margin:0 0 6px}
  header.app h1{margin:0;font-size:1.5rem;letter-spacing:-.01em}
  header.app p{margin:8px 0 0;color:#c7d4ef;font-size:.92rem;max-width:60ch}
  .meta-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}
  .chip{font-family:var(--mono);font-size:.72rem;letter-spacing:.04em;background:rgba(255,255,255,.1);
    border:1px solid rgba(255,255,255,.18);color:#e6edfb;padding:5px 10px;border-radius:999px}

  /* Progress */
  .progress-shell{margin:20px 0 16px}
  .progress-head{display:flex;justify-content:space-between;align-items:baseline;font-size:.82rem;color:var(--muted);margin-bottom:8px}
  .progress-head b{color:var(--ink);font-variant-numeric:tabular-nums}
  .bar{height:8px;background:#e6ebf4;border-radius:999px;overflow:hidden}
  .bar>i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--blue),#60a5fa);transition:width .35s ease}

  /* Card */
  .card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);padding:24px}
  .review-banner{display:none;align-items:center;gap:10px;background:var(--orange-bg);border:1px solid var(--orange-bd);
    color:#92580a;border-radius:10px;padding:10px 14px;font-size:.86rem;font-weight:600;margin-bottom:16px}
  .review-banner.show{display:flex}
  .q-eyebrow{font-family:var(--mono);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);margin-bottom:10px}
  .q-eyebrow .sec{color:var(--muted)}
  .q-text{font-size:1.12rem;font-weight:600;line-height:1.5;margin:0 0 6px}
  .q-hint{font-size:.78rem;color:var(--muted);margin:0 0 18px}

  .options{display:flex;flex-direction:column;gap:10px}
  .opt{display:flex;gap:12px;align-items:flex-start;width:100%;text-align:left;cursor:pointer;
    border:1.5px solid var(--line);background:#fff;border-radius:12px;padding:13px 15px;font:inherit;color:var(--ink);
    transition:border-color .15s,background .15s,box-shadow .15s}
  .opt:hover:not(:disabled){border-color:#bcd0f7;background:#f8faff}
  .opt:focus-visible{outline:3px solid #bcd0f7;outline-offset:2px}
  .opt:disabled{cursor:default}
  .opt .key{flex:0 0 26px;height:26px;border-radius:7px;display:grid;place-items:center;font-family:var(--mono);
    font-size:.8rem;font-weight:700;background:#eef2fb;color:var(--blue-dark)}
  .opt .body{flex:1;font-size:.95rem;padding-top:2px}
  .opt.correct{border-color:var(--green-bd);background:var(--green-bg)}
  .opt.correct .key{background:var(--green);color:#fff}
  .opt.wrong{border-color:var(--red-bd);background:var(--red-bg)}
  .opt.wrong .key{background:var(--red);color:#fff}
  .opt.dim{opacity:.62}

  .feedback{display:none;margin-top:18px;border-radius:12px;padding:14px 16px;font-size:.9rem}
  .feedback.show{display:block}
  .feedback.ok{background:var(--green-bg);border:1px solid var(--green-bd)}
  .feedback.no{background:var(--red-bg);border:1px solid var(--red-bd)}
  .feedback .verdict{font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:8px}
  .feedback.ok .verdict{color:#047857}
  .feedback.no .verdict{color:#b91c1c}
  .feedback .why{color:var(--ink-2)}

  /* Nav */
  .nav{display:flex;justify-content:space-between;gap:12px;margin-top:20px}
  .btn{font:inherit;font-weight:600;border-radius:11px;padding:12px 20px;cursor:pointer;border:1.5px solid transparent;transition:.15s}
  .btn:focus-visible{outline:3px solid #bcd0f7;outline-offset:2px}
  .btn.primary{background:var(--blue);color:#fff}
  .btn.primary:hover:not(:disabled){background:var(--blue-dark)}
  .btn.ghost{background:#fff;color:var(--ink-2);border-color:var(--line)}
  .btn.ghost:hover:not(:disabled){border-color:#cbd5e1;background:#f8fafc}
  .btn:disabled{opacity:.45;cursor:not-allowed}

  .dots{display:flex;flex-wrap:wrap;gap:7px;margin-top:22px;justify-content:center}
  .dot{width:26px;height:26px;border-radius:7px;border:1.5px solid var(--line);background:#fff;cursor:pointer;
    font-family:var(--mono);font-size:.66rem;color:var(--muted);display:grid;place-items:center;padding:0;transition:.12s}
  .dot:hover{border-color:#bcd0f7}
  .dot.answered{background:#eef2fb;border-color:#cdd9f5;color:var(--blue-dark);font-weight:700}
  .dot.current{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.18);color:var(--blue);font-weight:700}
  .dot.answered.current{background:var(--blue);color:#fff}

  /* Glossary terms */
  .gloss{color:var(--blue-dark);border-bottom:1.5px dotted #93b4f3;cursor:help;font-weight:600}
  #gloss-pop{position:fixed;z-index:60;max-width:300px;background:#fff;border:1px solid var(--line);
    box-shadow:0 12px 32px rgba(15,31,61,.18);border-radius:12px;padding:13px 15px;font-size:.85rem;color:var(--ink-2);display:none}
  #gloss-pop b{display:block;color:var(--ink);font-size:.8rem;font-family:var(--mono);letter-spacing:.04em;text-transform:uppercase;margin-bottom:5px}

  /* Results */
  .results{display:none}
  .score-card{background:var(--card);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);
    padding:28px;text-align:center;margin-bottom:18px}
  .score-ring{font-size:3.2rem;font-weight:800;letter-spacing:-.02em;line-height:1;font-variant-numeric:tabular-nums}
  .score-sub{color:var(--muted);margin-top:6px;font-size:.95rem}
  .badge{display:inline-flex;align-items:center;gap:8px;margin-top:16px;padding:9px 18px;border-radius:999px;font-weight:700;font-size:.92rem}
  .badge.pass{background:var(--green-bg);color:#047857;border:1px solid var(--green-bd)}
  .badge.fail{background:var(--red-bg);color:#b91c1c;border:1px solid var(--red-bd)}
  .msg-card{background:#fff;border:1px solid var(--line);border-left:4px solid var(--blue);border-radius:12px;padding:18px 20px;margin-bottom:18px}
  .msg-card h3{margin:0 0 6px;font-size:1.05rem}
  .msg-card p{margin:0;color:var(--ink-2);font-size:.92rem}

  .panel{background:#fff;border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);padding:20px 22px;margin-bottom:18px}
  .panel h3{margin:0 0 14px;font-size:.95rem;font-family:var(--mono);letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .sec-row{display:flex;align-items:center;gap:12px;padding:11px 14px;border-radius:10px;margin-bottom:8px;font-size:.9rem}
  .sec-row .nm{flex:1;font-weight:600}
  .sec-row .pct{font-family:var(--mono);font-weight:700;font-variant-numeric:tabular-nums}
  .sec-row.good{background:var(--green-bg);border:1px solid var(--green-bd)}
  .sec-row.good .pct{color:#047857}
  .imp{border-radius:10px;padding:13px 15px;margin-bottom:10px}
  .imp.mid{background:var(--orange-bg);border:1px solid var(--orange-bd)}
  .imp.low{background:var(--red-bg);border:1px solid var(--red-bd)}
  .imp .top{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .imp .nm{font-weight:700;font-size:.92rem}
  .imp .pct{font-family:var(--mono);font-weight:700}
  .imp.mid .pct{color:#b45309}.imp.low .pct{color:#b91c1c}
  .imp .step{font-size:.84rem;color:var(--ink-2);margin-top:6px}

  .wrong-list{max-height:460px;overflow:auto;padding-right:6px}
  .wr{border:1px solid var(--line);border-radius:12px;padding:15px 16px;margin-bottom:12px}
  .wr .wq{font-weight:600;font-size:.92rem;margin-bottom:10px}
  .wr .wn{font-family:var(--mono);font-size:.7rem;color:var(--muted);letter-spacing:.06em}
  .wr .ln{font-size:.86rem;margin:4px 0;padding-left:10px;border-left:3px solid var(--line)}
  .wr .ln.you{border-color:var(--red);color:#b91c1c}
  .wr .ln.ans{border-color:var(--green);color:#047857;font-weight:600}
  .wr .ex{font-size:.85rem;color:var(--ink-2);margin-top:10px;background:#f8fafc;border-radius:8px;padding:10px 12px}
  .actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:6px}
  .actions .btn{flex:1;min-width:160px;text-align:center}

  .note{font-size:.78rem;color:var(--muted);text-align:center;margin-top:26px;line-height:1.6}
  @media(max-width:560px){
    .wrap{padding:16px 12px 64px}
    .card{padding:18px}
    .nav{flex-direction:column-reverse}
    .nav .btn{width:100%}
    header.app h1{font-size:1.25rem}
  }
  @media(prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
